# ===========================================
# NeetResearch App - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your API keys

# =====================================
# Google Gemini API Keys
# =====================================
# Get keys from: https://ai.google.dev
# Free tier: 5-15 RPM depending on model
# Using multiple keys allows more requests!

# Your main API key
GOOGLE_API_KEY=AIza...your_main_key_here

# Additional keys (from friends/other accounts) for higher throughput
# Each key adds ~5 RPM capacity
Takunda_api_key=AIza...key_here
kudzaishe_api_key=AIza...key_here
patience_api_key=AIza...key_here
Nigel_api_key=AIza...key_here

# =====================================
# Google Custom Search API
# =====================================
# For web research functionality
# Get from: https://console.cloud.google.com/apis/credentials
# Create Custom Search Engine: https://programmablesearchengine.google.com/

GOOGLE_CSE_ID=your_custom_search_engine_id
GOOGLE_SEARCH_API_KEY=AIza...search_key_here

# =====================================
# Optional: Anthropic Claude API
# =====================================
# Only if you have $5 signup credits
# Get from: https://console.anthropic.com

# ANTHROPIC_API_KEY=sk-ant-...

# =====================================
# Application Settings
# =====================================
# Uncomment and modify as needed

# DEBUG=true
# LOG_LEVEL=INFO
# SESSIONS_DIR=./research_sessions
